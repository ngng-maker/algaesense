# Template for local secrets -- copy to .env and fill in real values.
# .env itself is gitignored; this file (with no real values) is tracked
# so the expected keys are documented in the repo.

# Pi connection (e.g. via Tailscale, or your LAN IP)
ALGAESENSE_PI_HOST=
ALGAESENSE_PI_USER=pi
ALGAESENSE_PI_SSH_PASSWORD=

# Set once you've created the Slack app + Hermes profile (see docs/slack_and_hermes_setup.md).
# Hermes itself stores these in ~/.hermes/.env via `hermes config set` -- not read from here.
# Listed for reference only.
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# ANTHROPIC_API_KEY=
